{
"name": "TaskFlow Teams API",
"dockerComposeFile": [
    "../docker-compose.yml"
],
"service": "app",
"workspaceFolder": "/app",
"runServices": [
    "db",
    "app"
],
"shutdownAction": "stopCompose",
"overrideCommand": true,
"customizations": {
    "vscode": {
    "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
    ],
    "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic"
    }
    }
}
}